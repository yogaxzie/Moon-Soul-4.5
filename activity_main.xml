<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0B0C1A"
    android:padding="20dp">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/ic_game"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GAME PENGHASIL UANG"
        android:textColor="#4A6FFF"
        android:textSize="24sp"
        android:textStyle="bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Main dan dapatkan uang!"
        android:textColor="#A0A0B0"
        android:textSize="14sp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btn_play"
        android:layout_width="200dp"
        android:layout_height="50dp"
        android:text="MULAI MAIN"
        android:background="#4A6FFF"
        android:textColor="#FFFFFF"
        android:textSize="16sp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="v4.5"
        android:textColor="#2A2C45"
        android:textSize="12sp"
        android:layout_marginTop="20dp"/>

</LinearLayout>
